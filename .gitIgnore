# Create .gitignore with common Python ignores
@"
# Virtual Environment
df-venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# IDE files
.vscode/
.idea/

# Environment variables
.env
*.env

# Logs
*.log
"@ | Out-File -FilePath .gitignore -Encoding utf8